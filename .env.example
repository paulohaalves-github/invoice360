# Conta IMAP (obrigatório para sincronizar faturas)
IMAP_HOST=imap.exemplo.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=seu-email@exemplo.com
IMAP_PASS=sua-Invo@2000

# Caixa e filtro (opcional)
IMAP_FOLDER=INBOX
# Texto que o assunto deve conter (único filtro; não precisa ser igual)
IMAP_SEARCH_SUBJECT=Your 360dialog invoice
# Quantos e-mails mais recentes varrer por sync.
# 0 = sem limite (varre toda a pasta)
IMAP_MAX_MESSAGES=0
